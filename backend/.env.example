# Server Configuration
PORT=5000

# PostgreSQL / Supabase Local Database
DB_HOST=localhost
DB_PORT=54322
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS - Frontend URL
FRONTEND_URL=http://localhost:3000

# App Base URL (used in email verification links)
APP_BASE_URL=http://localhost:3000

# Email Provider (API-based)
# Recommended provider: Resend (https://resend.com)
EMAIL_PROVIDER=resend
RESEND_API_KEY=your-resend-api-key
RESEND_API_URL=https://api.resend.com/emails
EMAIL_FROM=you@yourdomain.com
EMAIL_FROM_NAME=Time2Travel
EMAIL_SEND_TIMEOUT_MS=10000
